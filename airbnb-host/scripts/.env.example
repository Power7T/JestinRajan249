# ============================================================
# Airbnb Host Assistant — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# Claude API (required for AI draft generation)
# Get yours at https://console.anthropic.com
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# Email — IMAP (incoming) + SMTP (outgoing)
#
# Gmail:
#   IMAP: imap.gmail.com:993
#   SMTP: smtp.gmail.com:587
#   PASSWORD: use an App Password (myaccount.google.com/apppasswords)
#
# Outlook / Hotmail:
#   IMAP: outlook.office365.com:993
#   SMTP: smtp-mail.outlook.com:587
#   PASSWORD: your regular Outlook password (or App Password if MFA)
#
# Yahoo:
#   IMAP: imap.mail.yahoo.com:993
#   SMTP: smtp.mail.yahoo.com:587
#   PASSWORD: App Password required
#
# Other providers: check your provider's IMAP/SMTP settings
# ------------------------------------------------------------
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ADDRESS=your@email.com
EMAIL_PASSWORD=your-app-password

# How often to check for new Airbnb emails (seconds)
EMAIL_POLL_SECONDS=30

# Timeout for IMAP connections (seconds) — prevents hanging on unresponsive servers
EMAIL_IMAP_TIMEOUT=20

# ------------------------------------------------------------
# WhatsApp
# Your personal WhatsApp number in E.164 format
# Example: +14155550123 (US), +447911123456 (UK), +919876543210 (IN)
# ------------------------------------------------------------
HOST_WHATSAPP_NUMBER=+1234567890

# ------------------------------------------------------------
# Internal security token
# Shared secret between router, email_watcher, and WhatsApp bot.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Leave blank for development / single-machine use (localhost only).
# ------------------------------------------------------------
INTERNAL_TOKEN=

# ------------------------------------------------------------
# Internal service ports (change only if there are conflicts)
# ------------------------------------------------------------
ROUTER_PORT=7771
WA_BOT_PORT=7772

# How many days to keep approved/skipped drafts in pending_drafts.json
DRAFT_TTL_DAYS=7

# ------------------------------------------------------------
# iCal Calendar Integration (Options 3+4 calendar watcher)
#
# How to find your iCal URL:
#   Airbnb app → Calendar → tap the gear/settings icon
#   → "Availability settings" → "Export Calendar" → copy the .ics link
#
# Single listing:
#   AIRBNB_ICAL_URL=https://www.airbnb.com/calendar/ical/123456.ics?c=TOKEN
#
# Multiple listings (comma-separated, same order as PROPERTY_NAMES):
#   AIRBNB_ICAL_URLS=https://...listing1.ics,https://...listing2.ics
# ------------------------------------------------------------
AIRBNB_ICAL_URL=

# Human-readable name(s) for your property/properties
# Used in check-in instructions and cleaner briefs
# Multiple listings: comma-separated (e.g. "Beach House,City Apartment")
PROPERTY_NAME=My Property

# How many hours before check-in to send the host a check-in draft (default: 24)
CHECKIN_NOTICE_HOURS=24

# What hour of checkout day to send the cleaner brief (24h clock, default: 11 = 11 AM)
CHECKOUT_BRIEF_HOUR=11

# Assumed check-in time for notice window calculation (24h clock, default: 15 = 3 PM)
DEFAULT_CHECKIN_HOUR=15

# How often to poll iCal feeds (minutes, default: 30)
CALENDAR_POLL_MINUTES=30

# What hour to offer guests an extension (2h before checkout by default)
# If CHECKOUT_BRIEF_HOUR=11, this defaults to 9 (9 AM)
EXTENSION_OFFER_HOUR=9

# Your Airbnb listing URL — included in post-checkout review request to guests
# Find it: Airbnb → your listing → share link
# Leave blank to use a generic message
AIRBNB_LISTING_URL=

# ------------------------------------------------------------
# Service providers — configure in scripts/vendors.json
# Add cleaners and AC technicians with WhatsApp numbers in E.164 format.
# The bot contacts them in order (primary first, then backups).
# ------------------------------------------------------------

# ------------------------------------------------------------
# Event data for /price-tip (optional)
# ------------------------------------------------------------
SERPAPI_KEY=
BRAVE_API_KEY=
