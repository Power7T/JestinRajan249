# Public test URL from `cloudflared tunnel --url http://localhost:8000`
APP_BASE_URL=https://replace-me.trycloudflare.com

# Trust Cloudflare proxy headers so HTTPS-aware cookies and redirects work.
TRUST_PROXY_HEADERS=1

# Optional overrides for public webhook testing.
INBOUND_PARSE_WEBHOOK_SECRET=dev-inbound-secret
