# ============================================================
# Airbnb Host Assistant — Web SaaS Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# -- Database --
# SQLite (dev, no setup needed):
DATABASE_URL=sqlite:///./airbnb_host.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://hostai:YOURPASSWORD@localhost:5432/hostai

# -- Web app secrets --
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# -- Field encryption key --
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: changing this key will invalidate all stored encrypted values (email passwords, API keys)
FIELD_ENCRYPTION_KEY=

# -- Docker Compose --
POSTGRES_PASSWORD=changeme

# -- Port (default 8000) --
PORT=8000

# -- Session lifetime (hours) --
SESSION_HOURS=72
