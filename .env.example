# ============================================================
# HostAI — Web SaaS Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# -- Database --
# SQLite (dev, no setup needed):
DATABASE_URL=sqlite:///./airbnb_host.db
# PostgreSQL (production — set automatically by docker-compose):
# DATABASE_URL=postgresql://hostai:YOURPASSWORD@db:5432/hostai

# -- Redis (shared rate limiting + Baileys queue across workers) --
# Set automatically by docker-compose. Override for external Redis:
REDIS_URL=redis://redis:6379/0

# -- Web app secrets --
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# -- Field encryption key --
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: changing this key will invalidate all stored encrypted values (email passwords, API keys)
FIELD_ENCRYPTION_KEY=

# -- Docker Compose --
POSTGRES_PASSWORD=changeme

# -- PostgreSQL streaming replication --
# Required if using the read replica (docker compose --profile replica up).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(20))"
REPLICATION_PASSWORD=

# -- Read replica URL (optional) --
# When the replica is running, point this at it.
# docker compose --profile replica up sets db-replica on port 5432 internally.
# Set to: postgresql://hostai:YOURPASSWORD@db-replica:5432/hostai
DATABASE_REPLICA_URL=

# -- Port (default 8000) --
PORT=8000

# -- Workers (uvicorn workers; 2 is good for 1-2 CPU cores) --
WORKERS=2

# -- Environment --
ENVIRONMENT=production

# -- Session lifetime (hours) --
SESSION_HOURS=72

# -- App public base URL (used for Stripe redirect URLs, webhook URLs, email links) --
APP_BASE_URL=https://your-domain.com

# -- SMTP (for email verification + password reset) --
# Any SMTP provider works: Gmail (use App Password), SendGrid, Mailgun, AWS SES, etc.
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=you@gmail.com
# SendGrid example: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@your-domain.com

# -- Stripe (payment processing) --
# Get from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products in Stripe dashboard, then paste price IDs here:
STRIPE_PRICE_BAILEYS=price_...
STRIPE_PRICE_META_CLOUD=price_...
STRIPE_PRICE_SMS=price_...
STRIPE_PRICE_PRO=price_...

# -- Error tracking (optional) --
# Get DSN from sentry.io → New Project → Python
SENTRY_DSN=

# -- SSL (used by deploy.sh and docker-compose certbot services) --
CERTBOT_EMAIL=admin@your-domain.com
DOMAIN=your-domain.com

# -- CI/CD (GitHub Actions secrets — set in GitHub, not here) --
# DEPLOY_HOST=your-server-ip
# DEPLOY_USER=ubuntu
# DEPLOY_KEY=<contents of ~/.ssh/hostai_deploy private key>
# DEPLOY_PATH=/srv/hostai
