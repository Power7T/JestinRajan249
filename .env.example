# ============================================================
# Airbnb Host Assistant — Web SaaS Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# -- Database --
# SQLite (dev, no setup needed):
DATABASE_URL=sqlite:///./airbnb_host.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://hostai:YOURPASSWORD@localhost:5432/hostai

# -- Web app secrets --
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# -- Field encryption key --
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: changing this key will invalidate all stored encrypted values (email passwords, API keys)
FIELD_ENCRYPTION_KEY=

# -- Docker Compose --
POSTGRES_PASSWORD=changeme

# -- Port (default 8000) --
PORT=8000

# -- Session lifetime (hours) --
SESSION_HOURS=72

# -- App public base URL (used for Stripe redirect URLs, webhook URLs, bot download) --
APP_BASE_URL=https://your-domain.com

# -- Stripe (payment processing) --
# Get from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products in Stripe dashboard, then paste price IDs here:
STRIPE_PRICE_BAILEYS=price_...
STRIPE_PRICE_META_CLOUD=price_...
STRIPE_PRICE_SMS=price_...
STRIPE_PRICE_PRO=price_...
